# Google Gemini API key (wymagany do Phase 2 — generowanie opisów)
GEMINI_API_KEY=AIza...

# ImgBB API key (Phase 4.6 — upload miniaturek, darmowy tier)
# Utwórz konto na imgbb.com → API → utwórz klucz
IMGBB_API_KEY=

# GS1 Polska API (mojegs1.pl) — opcjonalne
GS1_CLIENT_ID=
GS1_CLIENT_SECRET=

# BaseLinker API — wymagane dla scripts/sync_clone_stocks.py (synchronizacja stocków klonów multi-EAN)
# Token: BaseLinker → Moje konto → API → wygeneruj token
# Inventory ID: BaseLinker → Magazyn → ID katalogu (zwykle widoczne w URL listy produktów)
BASELINKER_TOKEN=
BASELINKER_INVENTORY_ID=

# OLX API (Faza 1 — kiedy zarejestrujesz aplikację w developer.olx.pl)
# 1. Utwórz aplikację: https://developer.olx.pl/
# 2. Redirect URI MUSI być: http://127.0.0.1:8765/callback
# 3. Wymagany scope: "v2 read write"
OLX_CLIENT_ID=
OLX_CLIENT_SECRET=
OLX_REDIRECT_URI=http://127.0.0.1:8765/callback
# Domyślne dane oferty (zapisywane w każdej publikacji, można nadpisać w GUI)
OLX_CONTACT_NAME=
OLX_CONTACT_PHONE=
OLX_LOCATION_CITY_ID=
