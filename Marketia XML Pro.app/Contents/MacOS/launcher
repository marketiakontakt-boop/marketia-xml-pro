#!/bin/bash
# Marketia XML Pro launcher.
#
# Strategy: Write a temporary LaunchAgent plist and bootstrap it via launchctl.
# LaunchAgents run in the user's Aqua session with full file access — no TCC
# restriction. The plist is removed immediately after bootstrap.

APP_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"
PYTHON="$HOME/Library/Application Support/MarketiaXMLPro/venv/bin/python"
LOG="$HOME/Library/Logs/MarketiaXMLPro.log"
LABEL="com.marketia.xmlpro.runner"
PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"

mkdir -p "$(dirname "$LOG")"
echo "--- $(date) LAUNCHER START ---" >> "$LOG" 2>/dev/null

if [ ! -x "$PYTHON" ]; then
  /usr/bin/osascript -e "display dialog \"Nie znaleziono środowiska Python.\nOczekiwana lokalizacja:\n$PYTHON\" buttons {\"OK\"} default button \"OK\" with icon stop with title \"Marketia XML Pro\""
  exit 1
fi

# Unload any stale previous instance
/bin/launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true

# Write LaunchAgent plist (to ~/Library, accessible without Documents TCC)
cat > "$PLIST" << PLISTEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>$LABEL</string>
    <key>ProgramArguments</key>
    <array>
        <string>$PYTHON</string>
        <string>-m</string>
        <string>app.main</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>$APP_DIR</string>
        <key>HOME</key>
        <string>$HOME</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>$LOG</string>
    <key>StandardErrorPath</key>
    <string>$LOG</string>
    <key>RunAtLoad</key>
    <true/>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
PLISTEOF

# Bootstrap (start) the agent
/bin/launchctl bootstrap "gui/$(id -u)" "$PLIST"
BOOT_EXIT=$?
echo "--- launchctl bootstrap exit=$BOOT_EXIT ---" >> "$LOG" 2>/dev/null

# Remove plist (agent stays running; removing plist just prevents re-launch on login)
sleep 0.5
rm -f "$PLIST"
